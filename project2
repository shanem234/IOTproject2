#define BLYNK_TEMPLATE_ID "TMPL4hgQZ3JNf"
#define BLYNK_TEMPLATE_NAME "immersion heater alerter"
#define BLYNK_AUTH_TOKEN "6sUan8E8PoUxlvX-dtnrlgQwmgQ11AgV"

#include <WiFi.h>
#include <BlynkSimpleWifi.h>
#include <Wire.h>
#include <rgb_lcd.h>
#include <math.h>

rgb_lcd lcd;
BlynkTimer timer;

char ssid[] = "shane";
char pass[] = "Shane123";

const int tempPin = A0;
const int ledPin = 6;
const int buzzerPin = 5;
const int relayPin = 7;       // Relay pin for immersion ON/OFF

const float thresholdTemp = 40.0;
const float highTempWarning = 40.0;
const unsigned long alertDuration = 10000;

unsigned long heaterStartTime = 0;
bool heaterOn = false;
bool alertSent = false;
bool immersionCommand = false;   // Controlled by Blynk button

float readTemperature() {
  int analogValue = analogRead(tempPin);

  float voltage = analogValue * (3.3 / 4095.0);
  float temperature = voltage * 100.0;

  return temperature;
}

// Blynk button on V4
BLYNK_WRITE(V4) {
  immersionCommand = param.asInt();

  if (immersionCommand) {
    digitalWrite(relayPin, HIGH);   // Turn immersion ON
  } else {
    digitalWrite(relayPin, LOW);    // Turn immersion OFF
  }
}

void checkHeaterStatus() {
  float temperature = readTemperature();
  unsigned long runtimeMinutes = 0;
  String alertMessage = "Safe";

  Serial.print("Temperature: ");
  Serial.println(temperature);

  lcd.setCursor(0, 0);
  lcd.print("Temp: ");
  lcd.print(temperature, 1);
  lcd.print(" C   ");

  if (immersionCommand) {
    lcd.setCursor(0, 1);
    lcd.print("Immersion is on");

    if (!heaterOn) {
      heaterOn = true;
      heaterStartTime = millis();
      alertSent = false;
    }

    runtimeMinutes = (millis() - heaterStartTime) / 60000;

    if (millis() - heaterStartTime > alertDuration) {
      digitalWrite(ledPin, HIGH);

      unsigned long currentTime = millis();
      if ((currentTime / 500) % 2 == 0) {
        digitalWrite(buzzerPin, HIGH);
      } else {
        digitalWrite(buzzerPin, LOW);
      }

      alertMessage = "Warning: ON too long";

      if (!alertSent) {
        Blynk.logEvent("heater_alert", "Immersion heater has been ON too long");
        alertSent = true;
      }
    } else {
      digitalWrite(ledPin, LOW);
      digitalWrite(buzzerPin, LOW);
      alertMessage = "Heating normally";
    }

    if (temperature > highTempWarning) {
      alertMessage = "High temp warning";
    }

  } else {
    heaterOn = false;
    alertSent = false;
    runtimeMinutes = 0;

    digitalWrite(ledPin, LOW);
    digitalWrite(buzzerPin, LOW);

    lcd.setCursor(0, 1);
    lcd.print("Immersion off   ");
    alertMessage = "Safe";
  }

  Blynk.virtualWrite(V0, temperature);
  Blynk.virtualWrite(V1, immersionCommand ? 1 : 0);
  Blynk.virtualWrite(V2, runtimeMinutes);
  Blynk.virtualWrite(V3, alertMessage);

  Serial.print("Heater status: ");
  Serial.println(immersionCommand ? "ON" : "OFF");

  Serial.print("Runtime (mins): ");
  Serial.println(runtimeMinutes);

  Serial.print("Alert: ");
  Serial.println(alertMessage);
}

void setup() {
  Serial.begin(115200);

  pinMode(ledPin, OUTPUT);
  pinMode(buzzerPin, OUTPUT);
  pinMode(relayPin, OUTPUT);

  digitalWrite(ledPin, LOW);
  digitalWrite(buzzerPin, LOW);
  digitalWrite(relayPin, LOW);

  lcd.begin(16, 2);
  lcd.print("Connecting...");

  Blynk.begin(BLYNK_AUTH_TOKEN, ssid, pass);

  lcd.clear();
  lcd.print("Temp Monitor");
  delay(1500);
  lcd.clear();

  timer.setInterval(1000L, checkHeaterStatus);
}

void loop() {
  Blynk.run();
  timer.run();
}
